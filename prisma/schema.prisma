generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminTheme {
  id        Int      @id @default(autoincrement())
  primary   String
  style     String
  tone      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTheme {
  id             Int      @id @default(autoincrement())
  preferredColor String
  style          String
  tone           Int
  density        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminSecurity {
  id        Int      @id @default(autoincrement())
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerProfile {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  nationalId String   @unique
  phone      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  carts      Cart[]
}

model Product {
  id          Int      @id @default(autoincrement())
  showcaseId  String?
  showcase    Showcase? @relation(fields: [showcaseId], references: [id])
  title       String
  description String
  price       String
  originalPrice   String?
  discountPrice   String?
  discountPercent Int?
  imageUrl    String?
  badge       String?
  ctaLabel    String?
  ctaHref     String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cartItems   CartItem[]
}

model Showcase {
  id        String    @id @default(cuid())
  title     String?
  description String?
  imageUrl  String?
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  banners   Banner[]
}

model Banner {
  id         String   @id @default(cuid())
  title      String?
  showcaseId String?
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  images     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  showcase   Showcase? @relation(fields: [showcaseId], references: [id])
}

model Cart {
  id        String          @id @default(cuid())
  profileId String
  status    String          @default("active")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  profile   CustomerProfile @relation(fields: [profileId], references: [id])
  items     CartItem[]

  @@unique([profileId, status])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  productId       Int?
  title           String
  description     String
  price           String
  originalPrice   String?
  discountPrice   String?
  discountPercent Int?
  imageUrl        String?
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}
