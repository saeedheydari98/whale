generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int               @id @default(autoincrement())
  email              String            @unique
  username           String?           @unique
  name               String?
  passwordHash       String?
  role               String            @default("user")
  refreshTokenHash   String?
  resetTokenHash     String?
  resetTokenExpiresAt DateTime?
  avatarUrl          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  profiles           CustomerProfile[]
  comments           Comment[]
  orders             Order[]
  adminRequests      AdminAccessRequest[]
}

model AdminTheme {
  id        Int      @id @default(autoincrement())
  primary   String
  style     String
  tone      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminSecurity {
  id            Int      @id @default(autoincrement())
  code          String
  isPanelLocked Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UserTheme {
  id                 Int      @id @default(autoincrement())
  preferredColor     String
  style              String
  tone               Int
  density            String
  isColorPanelLocked Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CustomerProfile {
  id              String   @id @default(cuid())
  userId          Int?
  firstName       String
  lastName        String
  nationalId      String   @unique
  phone           String
  avatarUrl       String?
  isAdminUnlocked Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id])
  carts           Cart[]
}

model Product {
  id              Int        @id @default(autoincrement())
  showcaseId      String?
  showcase        Showcase?  @relation(fields: [showcaseId], references: [id])
  showcaseIds     Json?
  title           String
  description     String
  slug            String?    @unique
  price           String
  originalPrice   String?
  discountPrice   String?
  discountPercent Int?
  imageUrl        String?
  images          Json?
  videoUrl        String?
  badge           String?
  ctaLabel        String?
  ctaHref         String?
  active          Boolean    @default(true)
  isActive        Boolean    @default(true)
  isFeatured      Boolean    @default(false)
  isAvailable     Boolean    @default(true)
  stockQuantity   Int        @default(0)
  stockStatus     String     @default("in_stock")
  minOrder        Int        @default(1)
  maxOrder        Int?
  weight          Float?
  length          Float?
  width           Float?
  height          Float?
  salesCount      Int        @default(0)
  views           Int        @default(0)
  wishlistCount   Int        @default(0)
  ratingAverage   Float      @default(0)
  ratingCount     Int        @default(0)
  discountStartAt DateTime?
  discountEndAt   DateTime?
  categoryId      String     @default("general")
  categoryIds     Json?
  manufactureYear Int?
  brand           String?
  vendor          String?
  sku             String?    @unique
  barcode         String?    @unique
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  placement       String?
  publishedAt     DateTime?
  deletedAt       DateTime?
  colorStock      Json?
  sortOrder       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  cartItems       CartItem[]
  comments        Comment[]
  orderItems      OrderItem[]
}

model Comment {
  id        String   @id @default(cuid())
  productId Int
  userId    Int?
  author    String
  content   String
  rating    Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model Showcase {
  id          String    @id @default(cuid())
  title       String?
  description String?
  imageUrl    String?
  active      Boolean   @default(true)
  mode        String    @default("manual")
  autoSort    String    @default("newest")
  limit       Int       @default(8)
  categoryId  String?
  manualProductIds Json?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  banners     Banner[]
}

model Category {
  id        String   @id
  title     String
  slug      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id         String    @id @default(cuid())
  title      String?
  showcaseId String?
  active     Boolean   @default(true)
  sortOrder  Int       @default(0)
  intervalSeconds Int   @default(5)
  heightPercent Int     @default(28)
  images     Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  showcase   Showcase? @relation(fields: [showcaseId], references: [id])
}

model Cart {
  id        String          @id @default(cuid())
  profileId String
  status    String          @default("active")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  profile   CustomerProfile @relation(fields: [profileId], references: [id])
  items     CartItem[]

  @@unique([profileId, status])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  productId       Int?
  title           String
  description     String
  price           String
  originalPrice   String?
  discountPrice   String?
  discountPercent Int?
  imageUrl        String?
  selectedColor   String?
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id        String      @id @default(cuid())
  userId    Int
  profileId String?
  status    String      @default("paid")
  total     String      @default("0")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     OrderItem[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       Int?
  title           String
  description     String
  price           String
  originalPrice   String?
  discountPrice   String?
  discountPercent Int?
  imageUrl        String?
  selectedColor   String?
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])
}

model AdminAccessRequest {
  id        String   @id @default(cuid())
  userId    Int
  username  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
