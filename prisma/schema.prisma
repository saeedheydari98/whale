generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminTheme {
  id        Int      @id @default(autoincrement())
  primary   String
  style     String
  tone      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTheme {
  id             Int      @id @default(autoincrement())
  preferredColor String
  style          String
  tone           Int
  density        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  showcaseId  String
  showcase    Showcase @relation(fields: [showcaseId], references: [id])
  title       String
  description String
  price       String
  originalPrice   String?
  discountPrice   String?
  discountPercent Int?
  imageUrl    String?
  badge       String?
  ctaLabel    String?
  ctaHref     String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Showcase {
  id        String    @id @default(cuid())
  title     String?
  description String?
  imageUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  banners   Banner[]
}

model Banner {
  id         String   @id @default(cuid())
  title      String?
  showcaseId String
  images     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  showcase   Showcase @relation(fields: [showcaseId], references: [id])
}
